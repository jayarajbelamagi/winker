# Copy values into Render → Environment (Web Service)

PORT=5000
NODE_ENV=production

MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dbname
JWT_SECRET=your-long-random-secret

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated — your Vercel production URL (and preview URLs if needed)
# Example: https://your-app.vercel.app,https://your-app-git-main-user.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Optional — AI chat (Hugging Face)
HF_API_KEY=
